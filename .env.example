# ── Shared ────────────────────────────────────────────────────────────────────
# Single API key used by both frontend and backend
API_KEY=your-api-key-here

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_DEV_MODE=true
VITE_X_INIT_DATA_KEY=your-api-key-here

# ── Backend ───────────────────────────────────────────────────────────────────
# DEV_MODE=true  → any string token works (for local dev without Telegram)
# DEV_MODE=false → Telegram initData is required and HMAC-verified via BOT_TOKEN
BOT_TOKEN=your-telegram-bot-token-here

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Public HTTPS URL where the Mini App is hosted (Telegram requires HTTPS)
# For local testing use ngrok: ngrok http 80 → https://xxxx.ngrok-free.app
WEBAPP_URL=https://your-domain.com
